#!/opt/pwn.college/bash
set -euo pipefail

normalize(){ printf '%s' "$1" | tr '[:lower:]' '[:upper:]'; }
digest(){
  if command -v sha256sum >/dev/null 2>&1; then
    printf '%s' "$1" | sha256sum | awk '{print $1}'
  else
    printf '%s' "$1" | shasum -a 256 | awk '{print $1}'
  fi
}
get_flag(){
  case "${DEBUG:-0}" in
    1|true|TRUE|on|ON) printf '%s\n' 'flag{challenge11_timestamp_forensics_debug}' ;;
    *) [[ -r /flag ]] && cat /flag || { echo "Release mode is enabled but /flag is not readable." >&2; exit 1; } ;;
  esac
}
expected_hash='006773a6c90796e52ff8dc43cd132bdc8cc885a2717ccbc87b70aa74acb5d1b8'
[[ "$#" -eq 1 ]] || { echo "Usage: $0 ANSWER" >&2; exit 1; }
provided="$(normalize "$1")"
[[ "$(digest "$provided")" == "$expected_hash" ]] || { echo "Incorrect answer." >&2; exit 1; }
echo "Correct."
get_flag
